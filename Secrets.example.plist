<?xml version="1.0" encoding="UTF-8"?>
<!--
  Phase 4 photo capture — Gemini API key template.

  To enable photo recognition:
    1. Copy this file to  tracklifts/Secrets.plist  (gitignored; auto-bundled by the
       synchronized file group).
    2. Replace the placeholder below with your Google Gemini API key.
  Or, for simulator runs, set GEMINI_API_KEY in the scheme's Run > Environment.

  Typed + voice capture work fully on-device and need no key.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>GeminiAPIKey</key>
	<string>YOUR_GEMINI_API_KEY_HERE</string>
</dict>
</plist>
